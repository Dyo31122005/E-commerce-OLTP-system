--  Goal   : Total revenue and total orders per day
--  Columns: date, total_orders, total_quantity, total_revenue
--  Filter : date range + optional product list
-- ============================================================
CREATE OR REPLACE FUNCTION rpt_daily_revenue(
    p_start_date DATE,
    p_end_date   DATE,
    p_product_ids INT[] DEFAULT NULL   -- NULL = all products
)
RETURNS TABLE (
    date           DATE,
    total_orders   BIGINT,
    total_quantity BIGINT,
    total_revenue  NUMERIC(18,2)
)
LANGUAGE plpgsql
AS $$
BEGIN
    IF p_start_date > p_end_date THEN
        RAISE EXCEPTION 'start_date (%) must be <= end_date (%)', p_start_date, p_end_date;
    END IF;

    RETURN QUERY
    SELECT
        o.order_date::DATE                    AS date,
        COUNT(DISTINCT o.order_id)            AS total_orders,
        COALESCE(SUM(oi.quantity), 0)::BIGINT AS total_quantity,
        COALESCE(SUM(oi.subtotal), 0)         AS total_revenue
    FROM orders o
    JOIN order_item oi ON oi.order_id = o.order_id
    WHERE o.order_date >= p_start_date::TIMESTAMP
      AND o.order_date <  (p_end_date + INTERVAL '1 day')::TIMESTAMP
      AND o.status NOT IN ('CANCELLED', 'RETURNED')
      -- product filter: skip if NULL (all products)
      AND (p_product_ids IS NULL OR oi.product_id = ANY(p_product_ids))
    GROUP BY o.order_date::DATE
    ORDER BY o.order_date::DATE;
END;
$$;

