INSERT INTO orders_partitioned
    (order_id, order_date, seller_id, status, total_amount, created_at)
SELECT
    order_id, order_date, seller_id, status, total_amount, created_at
FROM orders;

INSERT INTO order_item_partitioned
    (order_item_id, order_id, product_id, order_date,
     quantity, unit_price, subtotal, created_at)
SELECT
    order_item_id, order_id, product_id, order_date,
    quantity, unit_price, subtotal, created_at
FROM order_item;

